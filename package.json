{
  "name": "venomous-portfolio",
  "type": "module",
  "version": "3.0.0",
  "description": "Chen's personal portfolio — a multi-theme showcase of work, experiments, and craft built with Astro and React.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "astro dev --force --mode development --open",
    "build": "astro build --mode production",
    "preview": "astro preview",
    "astro": "astro",
    "check:astro": "astro check",
    "check:eslint": "eslint \"src/**/*.{js,ts,tsx,astro}\" --cache --cache-location=./.cache/.eslintcache",
    "check:prettier": "prettier --check \"src/**/*.{js,ts,tsx,astro,mdx}\"",
    "format:eslint": "eslint --fix \"src/**/*.{js,ts,tsx,astro}\"",
    "format:prettier": "prettier --write \"src/**/*.{js,ts,tsx,astro,mdx}\" --cache --cache-location=./.cache/.prettiercache",
    "check": "concurrently -g --kill-others-on-fail --names \"astro,eslint,prettier\" \"npm run check:astro\" \"npm run check:eslint\" \"npm run check:prettier\"",
    "format": "concurrently --names \"eslint,prettier\" \"npm run format:eslint\" \"npm run format:prettier\"",
    "clean-cache": "rm -rf .cache",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.1.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "astro": "^5.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-organize-imports": "^4.1.0",
    "sass": "^1.99.0"
  },
  "packageManager": "npm@10.5.1"
}
