---
import PageLayout from "@/layouts/PageLayout.astro";
import { PagesNebula } from "@/themes/nebula";
import {
  getFeaturedWorks,
  getLocaleThemeStaticPaths,
  getPageTitle,
  loadHomePageContent,
  type Locale,
} from "@/utils/i18n";
import type { Theme } from "@/utils/themes";

export function getStaticPaths() {
  return getLocaleThemeStaticPaths();
}

const { locale, theme } = Astro.params as { locale: Locale; theme: Theme };
const content = loadHomePageContent(locale);
const works = getFeaturedWorks(locale, 2);
---

<PageLayout locale={locale} theme={theme} title={getPageTitle(locale, "home")} activePage="home">
  {
    theme === "nebula" && (
      <PagesNebula.Home
        content={content}
        works={works}
        locale={locale}
        theme={theme}
        client:visible
      />
    )
  }
</PageLayout>
