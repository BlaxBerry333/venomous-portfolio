---
import PageLayout from "@/layouts/PageLayout.astro";
import { PagesNebula } from "@/themes/nebula";
import {
  getLocaleThemeStaticPaths,
  getPageTitle,
  loadAboutPageContent,
  type Locale,
} from "@/utils/i18n";
import type { Theme } from "@/utils/themes";

export function getStaticPaths() {
  return getLocaleThemeStaticPaths();
}

const { locale, theme } = Astro.params as { locale: Locale; theme: Theme };
const content = loadAboutPageContent(locale);
---

<PageLayout locale={locale} theme={theme} title={getPageTitle(locale, "about")} activePage="about">
  {
    theme === "nebula" && (
      <PagesNebula.About content={content} locale={locale} theme={theme} client:visible />
    )
  }
</PageLayout>
