---
import type { Locale, Theme } from "@/types";
import { getLocalizedUrl } from "@/utils/i18n";
import SiteHeaderLanguageSwitcher from "./SiteHeaderLanguageSwitcher.astro";
import SiteHeaderThemeSwitcherPC from "./SiteHeaderThemeSwitcherPC.astro";
import SiteHeaderThemeSwitcherMobile from "./SiteHeaderThemeSwitcherMobile.astro";

interface Props {
  locale: Locale;
  /** Current theme; absent on resume page. */
  theme?: Theme;
  /** Hide theme switcher in resume mode. */
  resume?: boolean;
  /** Active page slug for nav highlight. */
  activePage?: "home" | "works" | "about" | "codex" | "detail" | "resume";
}

const { locale, theme, resume = false } = Astro.props;

// Compute current "sub-path" within the [theme] segment, so theme swap keeps page.
// e.g. /venomous-portfolio/ja/manga/works/foo/ -> "/works/foo"
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const fullPath = Astro.url.pathname;
const subPath = (() => {
  const withoutBase = fullPath.replace(new RegExp(`^${base}`), "");
  const m = withoutBase.match(/^\/(?:ja|en|zh)\/(?:void|manga|zenless)(\/.*)?$/);
  if (!m) return "/";
  const tail = (m[1] ?? "/").replace(/\/$/, "");
  return tail || "/";
})();
---

<header class:list={["site-header", { "site-header-resume": resume }]}>
  <div class="site-header-inner">
    <a class="site-header-brand" href={getLocalizedUrl("/", locale, theme)}>
      CHEN<span class="site-header-brand-accent">.</span>
    </a>

    <div style="margin-right: auto;"></div>

    {
      !resume && (
        <>
          <SiteHeaderThemeSwitcherPC locale={locale} theme={theme} subPath={subPath} />
          <SiteHeaderThemeSwitcherMobile locale={locale} theme={theme} subPath={subPath} />
        </>
      )
    }

    <SiteHeaderLanguageSwitcher locale={locale} theme={theme} />
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--site-header-height);
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--theme-bg) 80%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid color-mix(in srgb, var(--theme-fg) 12%, transparent);
    font-family: var(--theme-font-mono);
    font-size: 13px;
  }

  .site-header-inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    width: 100%;
    height: 100%;
    padding: 0 var(--site-padding-x);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .site-header-inner {
      gap: 12px;
    }
    .site-header-brand,
    .site-header-brand-accent {
      font-size: 1.5rem;
    }
  }

  .site-header-brand {
    font-family: var(--theme-font-display);
    font-weight: 900;
    font-size: 2rem;
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--theme-fg);
    text-decoration: none;
  }

  .site-header-brand-accent {
    color: var(--theme-accent);
    font-size: 2rem;
  }
</style>
